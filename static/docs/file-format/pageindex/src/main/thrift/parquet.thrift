<!DOCTYPE html>
<!-- Local redirect to latest parquet-thrift file -->
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Redirecting to parquet.thrift on GitHub</title>
    <meta http-equiv="refresh" content="0; url=https://github.com/apache/parquet-format/blob/master/src/main/thrift/parquet.thrift">
    <link rel="canonical" href="https://github.com/apache/parquet-format/blob/master/src/main/thrift/parquet.thrift">
</head>
<body>
    <p>Redirecting to <a href="https://github.com/apache/parquet-format/blob/master/src/main/thrift/parquet.thrift">parquet.thrift on GitHub</a>...</p>
    <script>
        window.location.href = "https://github.com/apache/parquet-format/blob/master/src/main/thrift/parquet.thrift";
    </script>
</body>
</html>
